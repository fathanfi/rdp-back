DATABASE_URL="postgresql://redpush:redpush_password@localhost:5432/redpush_portal?schema=public"
PORT=4000
JWT_ACCESS_SECRET=super-access-secret
JWT_REFRESH_SECRET=super-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000

# Stripe (test secret key only: sk_test_…)
STRIPE_SECRET_KEY=sk_test_your_secret_key

# Optional: Stripe Product IDs per plan (a=Growth Lite, b=Growth Pro, c=Enterprise). Defaults are set in code for the sandbox catalog.
# PaymentIntent amount = first active Price on the product (prefers one-time). If lookup fails, the app falls back to the client amount.
# STRIPE_PRODUCT_PLAN_A=prod_UV6qb1RHZEm55g
# STRIPE_PRODUCT_PLAN_B=prod_UV6qEwzr7QaQLa
# STRIPE_PRODUCT_PLAN_C=prod_UV6r3GELg5dynC

# AES-GCM secret for one-time login codes after checkout (min 16 characters)
CHECKOUT_CODE_SECRET=change-me-to-a-long-random-string
